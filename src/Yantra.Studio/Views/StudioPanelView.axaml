<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Yantra.Studio.Views.StudioPanelView">
  <DockPanel>
    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
      <TextBlock Classes="panel-title" Text="{Binding Title}" Foreground="#E7ECF5" />
      <TextBlock Classes="muted" Text="{Binding Subtitle}" />
    </StackPanel>
    <ScrollViewer>
      <ItemsControl ItemsSource="{Binding Lines}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Background="#101621" CornerRadius="5" Padding="7" Margin="0,0,0,5">
              <TextBlock Text="{Binding}" Foreground="#D7DEEA" FontSize="12" TextWrapping="Wrap" />
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </DockPanel>
</UserControl>
