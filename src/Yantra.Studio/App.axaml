<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Yantra.Studio.ViewModels"
             xmlns:views="clr-namespace:Yantra.Studio.Views"
             x:Class="Yantra.Studio.App">
  <Application.Styles>
    <FluentTheme />
    <Style Selector="Border.panel-card">
      <Setter Property="Background" Value="#151923" />
      <Setter Property="BorderBrush" Value="#2A3140" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="10" />
    </Style>
    <Style Selector="TextBlock.panel-title">
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Margin" Value="0,0,0,8" />
    </Style>
    <Style Selector="TextBlock.muted">
      <Setter Property="Foreground" Value="#AAB3C5" />
      <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="Button.toolbar-button">
      <Setter Property="Margin" Value="3,0" />
      <Setter Property="Padding" Value="12,5" />
    </Style>
  </Application.Styles>
  <Application.DataTemplates>
    <DataTemplate DataType="{x:Type vm:CanvasDocumentViewModel}">
      <views:CanvasDocumentView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:TextDocumentViewModel}">
      <views:TextDocumentView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:StudioPanelViewModel}">
      <views:StudioPanelView />
    </DataTemplate>
  </Application.DataTemplates>
</Application>
