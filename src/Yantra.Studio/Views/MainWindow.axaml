<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Yantra.Studio.Views.MainWindow"
        Title="Yantra.Studio"
        Width="1280"
        Height="820"
        MinWidth="980"
        MinHeight="640"
        Background="#0B0F16">
  <DockPanel>
    <Menu DockPanel.Dock="Top">
      <MenuItem Header="_Project">
        <MenuItem Header="New System Canvas" Command="{Binding Commands.NewCanvas}" />
        <MenuItem Header="Save" Command="{Binding Commands.Save}" />
      </MenuItem>
      <MenuItem Header="_Edit">
        <MenuItem Header="Add Block" Command="{Binding Commands.AddBlock}" />
      </MenuItem>
      <MenuItem Header="_View">
        <MenuItem Header="Zoom To Fit" Command="{Binding Commands.ZoomToFit}" />
        <MenuItem Header="Reset Layout" Command="{Binding Commands.ResetLayout}" />
      </MenuItem>
      <MenuItem Header="_Build">
        <MenuItem Header="Generate Build Plan" Command="{Binding Commands.Build}" />
      </MenuItem>
      <MenuItem Header="_Tools">
        <MenuItem Header="Command Palette" Command="{Binding Commands.ShowCommandPalette}" />
      </MenuItem>
    </Menu>

    <Border DockPanel.Dock="Top" Background="#111722" BorderBrush="#252D3B" BorderThickness="0,0,0,1" Padding="8">
      <DockPanel>
        <StackPanel Orientation="Horizontal">
          <Button Classes="toolbar-button" Content="New Canvas" Command="{Binding Commands.NewCanvas}" />
          <Button Classes="toolbar-button" Content="Add Block" Command="{Binding Commands.AddBlock}" />
          <Button Classes="toolbar-button" Content="Zoom Fit" Command="{Binding Commands.ZoomToFit}" />
          <Button Classes="toolbar-button" Content="Build" Command="{Binding Commands.Build}" />
        </StackPanel>
        <TextBlock DockPanel.Dock="Right" Text="Yantra graphical workspace" Foreground="#AAB3C5" VerticalAlignment="Center" />
      </DockPanel>
    </Border>

    <Border DockPanel.Dock="Bottom" Background="#111722" BorderBrush="#252D3B" BorderThickness="0,1,0,0" Padding="8,4">
      <DockPanel>
        <TextBlock Text="●" Foreground="#55D48B" Margin="0,0,8,0" />
        <TextBlock Text="{Binding StatusText}" Foreground="#D7DEEA" />
      </DockPanel>
    </Border>

    <Grid RowDefinitions="*,6,210" ColumnDefinitions="270,6,*,6,320" Margin="8">
      <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="3" Classes="panel-card">
        <TabControl ItemsSource="{Binding LeftPanels}">
          <TabControl.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Title}" />
            </DataTemplate>
          </TabControl.ItemTemplate>
        </TabControl>
      </Border>

      <GridSplitter Grid.Row="0" Grid.Column="1" Grid.RowSpan="3" Width="6" HorizontalAlignment="Stretch" Background="#0B0F16" />

      <Border Grid.Row="0" Grid.Column="2" Background="#0E131C" BorderBrush="#252D3B" BorderThickness="1" CornerRadius="8">
        <TabControl ItemsSource="{Binding Documents}" SelectedItem="{Binding ActiveDocument}">
          <TabControl.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Title}" />
            </DataTemplate>
          </TabControl.ItemTemplate>
        </TabControl>
      </Border>

      <GridSplitter Grid.Row="0" Grid.Column="3" Grid.RowSpan="3" Width="6" HorizontalAlignment="Stretch" Background="#0B0F16" />

      <Border Grid.Row="0" Grid.Column="4" Grid.RowSpan="3" Classes="panel-card">
        <TabControl ItemsSource="{Binding RightPanels}">
          <TabControl.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Title}" />
            </DataTemplate>
          </TabControl.ItemTemplate>
        </TabControl>
      </Border>

      <GridSplitter Grid.Row="1" Grid.Column="2" Height="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#0B0F16" />

      <Border Grid.Row="2" Grid.Column="2" Classes="panel-card">
        <TabControl ItemsSource="{Binding BottomPanels}">
          <TabControl.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Title}" />
            </DataTemplate>
          </TabControl.ItemTemplate>
        </TabControl>
      </Border>
    </Grid>
  </DockPanel>
</Window>
